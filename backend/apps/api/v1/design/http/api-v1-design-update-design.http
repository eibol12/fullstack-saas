{
  "email": "{{first_username}}",
  "password": "{{first_password}}"
}

> {%
    client.global.set("access_token", response.body.access);
%}

###
PATCH {{host}}/api/v1/design/{{design_id}}/
Authorization: Bearer {{access_token}}
Content-Type: application/json

