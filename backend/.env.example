DJANGO_ENV=dev
DJANGO_DEBUG=True
# Set to DEBUG to see the full rigging pipeline funnel; WARNING shows only failures.
LOG_LEVEL=WARNING
DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DATABASE_URL=sqlite:///db.sqlite3
DATABASE_URL_DIRECT=sqlite:///db.sqlite3
CONN_MAX_AGE=60

CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173

EMAIL_BACKEND=anymail.backends.resend.EmailBackend
DEFAULT_FROM_EMAIL="Grispen Tech <no-reply@auth.grispentech.com>"
# Frontend URL for email verification and password reset redirects
FRONTEND_URL=http://localhost:5173

STRIPE_API_KEY=stripe-api-key
STRIPE_PUBLISHABLE_KEY=stripe-publishable-key
STRIPE_WEBHOOK_SECRET_LOCAL=stripe-webhook-secret-local
STRIPE_PRICE_STARTER_MONTH=price_x
STRIPE_PRICE_STARTER_YEAR=price_x
STRIPE_PRICE_PRO_MONTH=price_x
STRIPE_PRICE_PRO_YEAR=price_x

RESEND_API_KEY=resend-api-key
